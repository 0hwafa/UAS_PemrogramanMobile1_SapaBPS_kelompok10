<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/detail_queue_title"
            app:navigationIcon="?attr/homeAsUpIndicator"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_queue_badge"
                android:padding="24dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:id="@+id/tvQueueNumberBig"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-001"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENUNGGU"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_badge" />
            </LinearLayout>

            <!-- QR Code Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/qr_code_label"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:contentDescription="@string/qr_code_desc" />
            </LinearLayout>

            <!-- Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/agency_name"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvAgencyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agency"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/phone_number"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvPhoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/visit_purpose"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvRemarks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remarks"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/registration_time"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Actions -->
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancel_queue"
                android:textColor="@color/statusBatal"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/statusBatal"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutAdminActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnServe"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_serve"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnComplete"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_complete"
                    android:backgroundTint="@color/statusSelesai" />
            </LinearLayout>

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_delete_ticket"
                android:textColor="@color/statusBatal"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
