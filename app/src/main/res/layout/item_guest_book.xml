<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_margin="8dp"
    android:padding="16dp"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/tvQueueNumber"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="A-001"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary" />
            
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MENUNGGU"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_status_badge" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAgencyName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nama Instansi"
        android:textSize="16sp"
        android:textColor="@color/textColorPrimary"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvRemarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tujuan Kunjungan"
        android:textSize="14sp"
        android:textColor="@color/textColorSecondary"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="05 Jul 2026, 13:45 WIB"
        android:textSize="12sp"
        android:textColor="@color/textColorSecondary"
        android:layout_marginTop="8dp"
        android:textAlignment="viewEnd" />
        
</LinearLayout>
